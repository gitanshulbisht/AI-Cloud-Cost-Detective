# ── Database ─────────────────────────────────────────────────────────────────
# Local Docker PostgreSQL (mock / dev mode)
# DATABASE_URL="postgresql://jules:jules@127.0.0.1:5432/aicloudcost"

# Azure Database for PostgreSQL Flexible Server (real Azure mode)
DATABASE_URL="postgresql://pgadmin:<your-password>@costdetective-pg.postgres.database.azure.com/costdetectivedb?ssl=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET="supersecretjwtkeythatshouldbechanged"

# ── NVIDIA NIM (AI) ───────────────────────────────────────────────────────────
# Get your key from https://build.nvidia.com
NVIDIA_API_KEY="nvapi-your-key-here"

# ── Azure Integration ─────────────────────────────────────────────────────────
# Your Azure Subscription ID (az account show --query id -o tsv)
AZURE_SUBSCRIPTION_ID="your-subscription-id-here"

# Set to "true" to use hardcoded mock data (no Azure account needed for local dev)
# Set to "false" to use the real Azure Python SDK against your subscription
USE_MOCK_AZURE_CLI="false"
